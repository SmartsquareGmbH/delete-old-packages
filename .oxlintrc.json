{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist"],
  "options": {
    "maxWarnings": 0,
    "typeAware": true
  },
  "rules": {
    "consistent-type-imports": "error"
  },
  "overrides": [
    {
      "files": ["test/**.ts"],
      "rules": { "unbound-method": "off" }
    }
  ]
}
