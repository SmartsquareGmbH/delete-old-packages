{
  "name": "delete-old-packages",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action for deleting old packages",
  "license": "MIT",
  "author": "Ruben Gees",
  "contributors": [
    "Ruben Gees",
    "Prom3theu5",
    "tisoft"
  ],
  "repository": "https://github.com/SmartsquareGmbH/delete-old-packages",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "start": "local-action . src/main.ts .env",
    "build": "rolldown -c",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "verify": "pnpm format:check && pnpm lint && pnpm check && pnpm test"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-throttling": "^11.0.3",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@github/local-action": "7.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.3",
    "@types/semver": "7.7.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "msw": "2.15.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "rolldown": "1.1.5",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "vitest-mock-extended": "4.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
