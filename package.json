{
  "name": "delete-old-packages",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action for deleting old packages",
  "license": "MIT",
  "author": "Ruben Gees",
  "contributors": [
    "Ruben Gees",
    "Prom3theu5",
    "tisoft"
  ],
  "repository": "https://github.com/SmartsquareGmbH/delete-old-packages",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "start": "local-action . src/main.ts .env",
    "build": "rolldown -c",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsgo --noEmit",
    "test": "vitest run",
    "verify": "pnpm format:check && pnpm lint && pnpm check && pnpm test"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-throttling": "^11.0.3",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@github/local-action": "^7.0.1",
    "@types/node": "^24.12.0",
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "7.0.0-dev.20260327.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.10",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.17.0",
    "rolldown": "1.0.0-rc.12",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
