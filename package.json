{
  "name": "delete-old-packages",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action for deleting old packages",
  "license": "MIT",
  "author": "Ruben Gees",
  "contributors": [
    "Ruben Gees",
    "Prom3theu5",
    "tisoft"
  ],
  "repository": "https://github.com/SmartsquareGmbH/delete-old-packages",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "start": "local-action . src/main.ts .env",
    "build": "rolldown -c",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsgo --noEmit",
    "test": "vitest run",
    "verify": "pnpm format:check && pnpm lint && pnpm check && pnpm test"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-throttling": "^11.0.3",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@github/local-action": "7.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.2",
    "@types/semver": "7.7.1",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "msw": "2.14.6",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "rolldown": "1.1.1",
    "vitest": "4.1.8",
    "vitest-mock-extended": "4.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
